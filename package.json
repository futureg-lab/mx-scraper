{
  "name": "mx-scraper",
  "version": "3.3.2",
  "description": "Manga website scraper",
  "main": "index.js",
  "scripts": {
    "test": "npx jest --runInBand",
    "start": "npx tsc --watch",
    "ts-node": "ts-node",
    "build": "npx tsc && pkg --compress GZip -t node18-x64 ."
  },
  "bin": {
    "mx-scraper": "./dist/cli.js"
  },
  "pkg": {
    "scripts": "dist",
    "outputPath": "bin"
  },
  "jest": {
    "testTimeout": 60000,
    "verbose": true,
    "modulePathIgnorePatterns": [
      "dist"
    ],
    "preset": "ts-jest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/futureg-lab/mx-scraper.git"
  },
  "keywords": [
    "web-scraping",
    "manga",
    "plugin"
  ],
  "engines": {
    "node": ">=14"
  },
  "author": "futureg-lab",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/futureg-lab/mx-scraper/issues"
  },
  "homepage": "https://github.com/futureg-lab/mx-scraper#readme",
  "devDependencies": {
    "@babel/preset-typescript": "^7.23.2",
    "@types/cli-progress": "^3.11.3",
    "@types/fs-extra": "^9.0.13",
    "@types/jest": "^28.1.8",
    "jest": "^28.1.3",
    "ts-jest": "^28.0.8",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  },
  "dependencies": {
    "axios": "^0.27.2",
    "cheerio": "^1.0.0-rc.12",
    "cli-progress": "^3.12.0",
    "fs-extra": "^10.1.0",
    "outdent": "^0.8.0",
    "puppeteer": "^21.3.8",
    "yaml": "^2.3.3"
  }
}
