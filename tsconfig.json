{
    "compilerOptions": {
        "moduleResolution": "Node",
        "target": "ES2021",
        "module": "CommonJS",
        "removeComments": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "allowJs" : true
    },
    "include": ["src"],
    "exclude": ["node_modules"],
    "esModuleInterop" : true
}